# Copy to .env and fill in with real credentials.
# Never commit the .env file — it's gitignored for a reason.
#
# Each org in config/orgs.yaml references two env vars by name
# (username_env / password_env). Keep them unique per org.

SF_PROD_US_USER=your-user@example.com
SF_PROD_US_PASS=your-password-or-token

SF_STAGE_EU_USER=your-user@example.com
SF_STAGE_EU_PASS=your-password-or-token

# Optional: set to "true" to run with a visible browser (useful while debugging).
HEADED=false

# Optional: default log level — DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO
